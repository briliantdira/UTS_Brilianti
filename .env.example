# Salin file ini jadi .env untuk development lokal (file .env tidak di-commit ke Git)

# Generate dengan:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=ganti-dengan-secret-key-random

# Development lokal
DEBUG=True

# Production: isi domain Railway kamu, pisahkan dengan koma jika lebih dari satu
# ALLOWED_HOSTS=web-dira-production.up.railway.app
